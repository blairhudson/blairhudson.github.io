---
import "@phosphor-icons/web/regular";
import "../styles/tokens.css";
import "../styles/global.css";
import "@xterm/xterm/css/xterm.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, shrink-to-fit=no, viewport-fit=cover, interactive-widget=resizes-content"
    />
    <title>BlairOS v2 | Blair Hudson</title>
    <meta name="title" content="BlairOS v2 | Blair Hudson" />
    <meta
      name="description"
      content="BlairOS v2 is a desktop OS interface for Blair Hudson, with terminal, browser, files, bin, trash, links, projects, writing, and research."
    />
    <meta
      name="keywords"
      content="Blair Hudson, BlairOS, AI, software engineering, terminal, desktop OS, portfolio, Astro, Bun, Clawkeys, sbx-agents, Agile Weekend, Skillcraft, GitHub"
    />
    <meta name="author" content="Blair Hudson" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#05070f" />
    <meta name="application-name" content="BlairOS v2" />
    <meta itemprop="image" content="https://blairhudson.com/og-image.jpg" />
    <meta name="apple-mobile-web-app-title" content="BlairOS v2" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="format-detection" content="telephone=no" />
    <link rel="canonical" href="https://blairhudson.com/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="website" />
    <meta property="og:title" content="BlairOS v2 | Blair Hudson" />
    <meta
      property="og:description"
      content="A desktop OS interface with terminal, browser, files, bin, trash, projects, writing, and research links."
    />
    <meta property="og:url" content="https://blairhudson.com/" />
    <meta property="og:site_name" content="BlairOS v2" />
    <meta property="og:locale" content="en_AU" />
    <meta property="og:image" content="https://blairhudson.com/og-image.jpg" />
    <meta property="og:image:secure_url" content="https://blairhudson.com/og-image.jpg" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="BlairOS v2 desktop interface for Blair Hudson" />
    <link rel="image_src" href="https://blairhudson.com/og-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="BlairOS v2 | Blair Hudson" />
    <meta
      name="twitter:description"
      content="Blair Hudson's desktop OS: terminal, browser, files, apps, and project links."
    />
    <meta name="twitter:site" content="@blairhudson" />
    <meta name="twitter:creator" content="@blairhudson" />
    <meta name="twitter:image" content="https://blairhudson.com/og-image.jpg" />
    <meta name="twitter:image:alt" content="BlairOS v2 desktop interface for Blair Hudson" />

    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Blair Hudson",
        "url": "https://blairhudson.com/",
        "jobTitle": "AI and software engineering leader",
        "sameAs": [
          "https://github.com/blairhudson/clawkeys",
          "https://blairhudson.com/sbx-agents/",
          "https://blairhudson.com/agile-weekend/",
          "https://skillcraft.gg/",
          "https://linkedin.com/in/blairhudson",
          "https://sublight.substack.com",
          "https://github.com/blairhudson/",
          "https://fastapi-agents.blairhudson.com",
          "https://deployscience.com/publications/"
        ],
        "image": "https://blairhudson.com/og-image.jpg",
        "description": "Australian AI and software engineering leader."
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
